---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const useCases = (await getCollection('use-cases')).sort(
  (a, b) => b.data.updated.getTime() - a.data.updated.getTime(),
);

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const statusColor: Record<string, string> = {
  'idea': 'bg-gray-100 text-gray-700',
  'brief': 'bg-amber-100 text-amber-800',
  'active-development': 'bg-emerald-100 text-emerald-800',
  'piloting': 'bg-sky-100 text-sky-800',
  'handover': 'bg-violet-100 text-violet-800',
  'complete': 'bg-stone-200 text-stone-800',
  'on-hold': 'bg-orange-100 text-orange-800',
  'no-go': 'bg-rose-100 text-rose-800',
};

function slugFromId(id: string) {
  return id.replace(/\/brief$/i, '');
}

function splitPrograms(sp?: string): string[] {
  if (!sp) return [];
  return sp
    .split(';')
    .map((s) => s.trim())
    .filter(Boolean);
}

const allPrograms = Array.from(
  new Set(useCases.flatMap((uc) => splitPrograms(uc.data.science_program))),
).sort();
---

<BaseLayout title="CDH Use Cases — Portfolio">
  <header class="mb-10">
    <h1 class="font-display text-3xl text-[var(--color-cdh-blue)]">
      Use case portfolio
    </h1>
    <p class="mt-2 text-gray-700">
      Active use cases curated by the CGIAR Climate Data Hub. Each case has a
      champion, a coordinator, a lifecycle status, and an action plan that
      grows over time.
    </p>
  </header>

  {allPrograms.length > 0 && (
    <div id="program-filter" class="mb-6 flex flex-wrap gap-2">
      <button
        type="button"
        data-filter="all"
        class="filter-btn rounded border border-transparent bg-[var(--color-cdh-blue)] px-3 py-1 text-sm text-white"
      >
        All
      </button>
      {allPrograms.map((p) => (
        <button
          type="button"
          data-filter={p}
          class="filter-btn rounded border border-gray-300 px-3 py-1 text-sm text-gray-700"
        >
          {p}
        </button>
      ))}
    </div>
  )}

  <ul class="grid gap-4 md:grid-cols-2">
    {useCases.map((uc) => (
      <li
        data-programs={splitPrograms(uc.data.science_program).join('||')}
        class="rounded-lg border border-gray-200 p-5 transition-colors hover:border-[var(--color-cdh-blue)]"
      >
        <a
          href={`${base}/use-cases/${slugFromId(uc.id)}/`}
          class="block"
        >
          <div class="mb-2 flex flex-wrap gap-2 text-xs">
            <span class={`rounded px-2 py-0.5 ${statusColor[uc.data.status] ?? 'bg-gray-100 text-gray-700'}`}>
              {uc.data.status}
            </span>
            <span class="rounded bg-gray-100 px-2 py-0.5 text-gray-700">{uc.data.type}</span>
            {uc.data.primary_aow && (
              <span class="rounded bg-[var(--color-cdh-blue-light)]/20 px-2 py-0.5 text-[var(--color-cdh-blue)]">
                {uc.data.primary_aow}
              </span>
            )}
            {splitPrograms(uc.data.science_program).map((p) => (
              <span class="rounded bg-indigo-100 px-2 py-0.5 text-indigo-800">{p}</span>
            ))}
          </div>
          <h2 class="font-display text-xl text-[var(--color-cdh-blue)]">
            {uc.data.title}
          </h2>
          <p class="mt-1 text-sm text-gray-700">{uc.data.description}</p>
          <p class="mt-3 text-xs text-gray-500">
            Champion: <span class="text-gray-700">{uc.data.champion}</span>
            {' '}· Updated {uc.data.updated.toISOString().slice(0, 10)}
          </p>
        </a>
      </li>
    ))}
  </ul>

  {useCases.length === 0 && (
    <div class="mt-8 rounded-lg border border-dashed border-gray-300 p-8 text-center text-gray-500">
      No use cases yet. Copy <code>BRIEF_TEMPLATE.md</code> into a new
      kebab-case folder as <code>BRIEF.md</code> to add one.
    </div>
  )}

  <script>
    const ACTIVE = ['bg-[var(--color-cdh-blue)]', 'text-white', 'border-transparent'];
    const INACTIVE = ['border-gray-300', 'text-gray-700'];
    const buttons = document.querySelectorAll<HTMLButtonElement>('#program-filter .filter-btn');
    const cards = document.querySelectorAll<HTMLLIElement>('ul li[data-programs]');

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const filter = btn.dataset.filter ?? 'all';

        buttons.forEach((b) => {
          const on = b === btn;
          b.classList.toggle('border', !on || true);
          ACTIVE.forEach((c) => b.classList.toggle(c, on));
          INACTIVE.forEach((c) => b.classList.toggle(c, !on));
        });

        cards.forEach((card) => {
          const progs = (card.dataset.programs ?? '').split('||').filter(Boolean);
          const show = filter === 'all' || progs.includes(filter);
          card.style.display = show ? '' : 'none';
        });
      });
    });
  </script>
</BaseLayout>
