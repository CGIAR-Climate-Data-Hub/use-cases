---
import type { CollectionEntry } from 'astro:content';
import { render } from 'astro:content';
import BaseLayout from './BaseLayout.astro';

interface Props {
  entry: CollectionEntry<'use-cases'>;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const fm = entry.data;

const statusColor: Record<typeof fm.status, string> = {
  'idea': 'bg-gray-100 text-gray-700',
  'brief': 'bg-amber-100 text-amber-800',
  'active-development': 'bg-emerald-100 text-emerald-800',
  'piloting': 'bg-sky-100 text-sky-800',
  'handover': 'bg-violet-100 text-violet-800',
  'complete': 'bg-stone-200 text-stone-800',
  'on-hold': 'bg-orange-100 text-orange-800',
  'no-go': 'bg-rose-100 text-rose-800',
};
---

<BaseLayout title={fm.title} description={fm.description}>
  <article>
    <header class="mb-8">
      <div class="mb-3 flex flex-wrap items-center gap-2 text-xs">
        <span class={`rounded px-2 py-1 ${statusColor[fm.status]}`}>{fm.status}</span>
        <span class="rounded bg-gray-100 px-2 py-1 text-gray-700">{fm.type}</span>
        <span class="rounded bg-gray-100 px-2 py-1 text-gray-700">{fm.origin}</span>
        {fm.primary_aow && (
          <span class="rounded bg-[var(--color-cdh-blue-light)]/20 px-2 py-1 text-[var(--color-cdh-blue)]">
            {fm.primary_aow}
          </span>
        )}
        {fm.ca_os_packages.map((p) => (
          <span class="rounded bg-gray-100 px-2 py-1 text-gray-700">{p}</span>
        ))}
      </div>
      <h1 class="font-display text-3xl text-[var(--color-cdh-blue)]">{fm.title}</h1>
      <p class="mt-2 text-gray-700">{fm.description}</p>
      <p class="mt-4 text-sm text-gray-500">
        Champion: <span class="font-medium text-gray-700">{fm.champion}</span>
        {fm.coordinator && (
          <>
            {' '}· Coordinator: <span class="font-medium text-gray-700">{fm.coordinator}</span>
          </>
        )}
        {' '}· Updated {fm.updated.toISOString().slice(0, 10)}
      </p>
    </header>
    <div class="prose prose-slate max-w-none">
      <Content />
    </div>
  </article>
</BaseLayout>
